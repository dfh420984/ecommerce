.container {
  min-height: 100vh;
  background: #f8f8f8;
  padding: 20rpx 24rpx 120rpx;
}

.status-card,
.address-card,
.goods-card,
.amount-card,
.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.status-text {
  display: block;
  font-size: 36rpx;
  color: #ff6b6b;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.status-desc,
.address-detail,
.value,
.goods-sku {
  font-size: 24rpx;
  color: #666;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.consignee {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.goods-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f4f4f4;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.goods-name {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 28rpx;
  color: #333;
}

.goods-sku {
  display: block;
  margin-top: 8rpx;
}

.goods-bottom,
.amount-row,
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-bottom {
  margin-top: 18rpx;
}

.goods-price,
.total-amount {
  color: #ff6b6b;
  font-weight: bold;
}

.goods-price {
  font-size: 30rpx;
}

.goods-quantity,
.label {
  font-size: 24rpx;
  color: #999;
}

.amount-row,
.info-row {
  padding: 10rpx 0;
  font-size: 26rpx;
  color: #333;
}

.total-row {
  margin-top: 10rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f4f4f4;
}

.total-amount {
  font-size: 34rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.action-btn {
  min-width: 180rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.plain-btn {
  color: #666;
  border: 1rpx solid #ddd;
  background: #fff;
}

.primary-btn {
  color: #fff;
  background: #ff6b6b;
}
