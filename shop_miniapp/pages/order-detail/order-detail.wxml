<view class="container" wx:if="{{order}}">
  <view class="status-card" wx:if="{{order}}">
    <text class="status-text {{order.order_status === 7 ? 'status-refunding' : ''}} {{order.order_status === 8 ? 'status-refunded' : ''}}">{{getStatusText(order.order_status)}}</text>
    <text class="status-desc">订单号：{{order.order_no}}</text>
    <view class="refund-tip" wx:if="{{order.order_status === 7 || order.order_status === 8}}">
      <text class="refund-icon">💰</text>
      <text class="refund-text">{{order.order_status === 7 ? '退款申请审核中，请耐心等待' : '退款已完成，款项已原路返回'}}</text>
      <view class="refund-detail-btn" bindtap="onViewRefundDetail">查看退款详情 ›</view>
    </view>
  </view>

  <view class="address-card">
    <view class="section-title">收货信息</view>
    <text class="consignee">{{order.consignee}} {{order.phone}}</text>
    <text class="address-detail">{{order.province}}{{order.city}}{{order.district}}{{order.address}}</text>
  </view>

  <view class="goods-card">
    <view class="section-title">商品信息</view>
    <view class="goods-item" wx:for="{{order.items}}" wx:key="id" bindtap="onProductTap" data-id="{{item.product_id}}">
      <image class="goods-image" src="{{item.product_image || '/static/product.png'}}" mode="aspectFill" />
      <view class="goods-info">
        <text class="goods-name">{{item.product_name}}</text>
        <text class="goods-sku" wx:if="{{item.sku_name}}">{{item.sku_name}}</text>
        <view class="goods-bottom">
          <text class="goods-price">¥{{item.price}}</text>
          <text class="goods-quantity">x{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="amount-card">
    <view class="amount-row">
      <text>商品总额</text>
      <text>¥{{order.total_amount}}</text>
    </view>
    <view class="amount-row" wx:if="{{order.coupon_amount > 0}}">
      <text>优惠金额</text>
      <text class="discount-amount">-¥{{order.coupon_amount}}</text>
    </view>
    <view class="amount-row">
      <text>运费</text>
      <text>¥{{order.freight_amount}}</text>
    </view>
    <view class="amount-row total-row">
      <text>实付款</text>
      <text class="total-amount">¥{{order.pay_amount}}</text>
    </view>
  </view>

  <view class="info-card">
    <view class="section-title">订单信息</view>
    <view class="info-row">
      <text class="label">下单时间</text>
      <text class="value">{{order.created_at}}</text>
    </view>
    <view class="info-row" wx:if="{{order.pay_time}}">
      <text class="label">支付时间</text>
      <text class="value">{{order.pay_time}}</text>
    </view>
    <view class="info-row" wx:if="{{order.express_company}}">
      <text class="label">物流公司</text>
      <text class="value" bindtap="onViewLogistics">{{order.express_company}} ›</text>
    </view>
    <view class="info-row" wx:if="{{order.express_no}}">
      <text class="label">快递单号</text>
      <text class="value" bindtap="onViewLogistics">{{order.express_no}} ›</text>
    </view>
    <view class="info-row" wx:if="{{order.cancel_time}}">
      <text class="label">取消时间</text>
      <text class="value">{{order.cancel_time}}</text>
    </view>
    <view class="info-row" wx:if="{{order.complete_time}}">
      <text class="label">完成时间</text>
      <text class="value">{{order.complete_time}}</text>
    </view>
    <view class="info-row" wx:if="{{order.remark}}">
      <text class="label">订单备注</text>
      <text class="value">{{order.remark}}</text>
    </view>
  </view>

  <!-- 底部操作按钮 -->
  <view class="bottom-bar">
    <!-- 删除订单：已取消或已完成 -->
    <view class="action-btn plain-btn" wx:if="{{order.order_status === 6 || order.order_status === 5}}" bindtap="onDeleteOrder">删除订单</view>
    <!-- 确认收货：配送中 -->
    <view class="action-btn plain-btn" wx:if="{{order.order_status === 3}}" bindtap="onConfirmReceive">确认收货</view>
    <!-- 取消订单：待付款 -->
    <view class="action-btn plain-btn" wx:if="{{order.order_status === 1}}" bindtap="onCancelOrder">取消订单</view>
    <!-- 立即支付：待付款 -->
    <view class="action-btn primary-btn" wx:if="{{order.order_status === 1}}" bindtap="onPay">立即支付</view>
    <!-- 申请退款：已支付且未完成/未取消/未退款 -->
    <view class="action-btn primary-btn" wx:if="{{order.pay_status === 1 && order.order_status !== 5 && order.order_status !== 6 && order.order_status !== 7 && order.order_status !== 8}}" bindtap="onApplyRefund">申请退款</view>
    <!-- 查看退款：退款中或已退款 -->
    <view class="action-btn primary-btn" wx:if="{{order.order_status === 7 || order.order_status === 8}}" bindtap="onViewRefundDetail">查看退款</view>
  </view>
</view>
