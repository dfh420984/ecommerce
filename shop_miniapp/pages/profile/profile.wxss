.container {
  min-height: 100vh;
  background: #f8f8f8;
  padding-bottom: 40rpx;
}

.profile-form {
  background: #fff;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  width: 140rpx;
  font-size: 28rpx;
  color: #333;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.readonly-text {
  flex: 1;
  font-size: 28rpx;
  color: #999;
  text-align: right;
}

/* 头像样式 */
.avatar-item {
  justify-content: space-between;
}

.avatar-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #f0f0f0;
}

.avatar-tip {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #999;
}

/* 保存按钮 */
.save-section {
  margin: 40rpx 30rpx;
}

.save-btn {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e8e 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  padding: 24rpx;
  border: none;
}

.save-btn::after {
  border: none;
}

.save-btn[loading] {
  opacity: 0.7;
}
