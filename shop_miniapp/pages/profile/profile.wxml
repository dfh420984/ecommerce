<view class="container">
  <view class="profile-form">
    <!-- 头像 -->
    <view class="form-item avatar-item" bindtap="onChooseAvatar">
      <text class="label">头像</text>
      <view class="avatar-preview">
        <image class="avatar-img" src="{{formData.avatar || '/static/user/avatar.png'}}" mode="aspectFill" />
        <view class="avatar-tip">点击更换</view>
      </view>
    </view>

    <!-- 昵称 -->
    <view class="form-item">
      <text class="label">昵称</text>
      <input class="input" placeholder="请输入昵称" value="{{formData.nickname}}" bindinput="onInputChange" data-field="nickname" maxlength="20" />
    </view>

    <!-- 手机号 -->
    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" placeholder="请输入手机号" value="{{formData.phone}}" bindinput="onInputChange" data-field="phone" maxlength="11" type="number" />
    </view>

    <!-- 邮箱 -->
    <view class="form-item">
      <text class="label">邮箱</text>
      <input class="input" placeholder="请输入邮箱" value="{{formData.email}}" bindinput="onInputChange" data-field="email" type="text" />
    </view>

    <!-- 用户名（只读） -->
    <view class="form-item">
      <text class="label">用户名</text>
      <text class="readonly-text">{{userInfo.username}}</text>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-section">
    <button class="save-btn" bindtap="onSave" loading="{{saving}}">保存</button>
  </view>
</view>
