.container {
  min-height: 100vh;
  background: #f8f8f8;
  padding-bottom: 100rpx;
}

.product-swiper {
  height: 750rpx;
  background: #fff;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-info {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.price {
  font-size: 48rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.original-price {
  font-size: 28rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 20rpx;
}

.product-name {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.product-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 点赞和收藏交互栏 */
.interaction-bar {
  display: flex;
  align-items: center;
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.interaction-item {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
  padding: 10rpx 20rpx;
  border-radius: 50rpx;
  background: #f8f8f8;
  transition: all 0.3s;
}

.interaction-item:active {
  transform: scale(0.95);
}

.interaction-item .icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.interaction-item .icon.active {
  animation: pulse 0.3s ease-in-out;
}

.interaction-item .count {
  font-size: 24rpx;
  color: #666;
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

.address-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.address-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.address-info {
  flex: 1;
}

.consignee {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.address-detail {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.no-address {
  font-size: 28rpx;
  color: #999;
}

.arrow {
  color: #ccc;
  font-size: 28rpx;
}

.product-content {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.content-html {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.content-html {
  max-width: 100%;
  box-sizing: border-box;
}

.content-html img,
.content-html p,
.content-html h1,
.content-html h2,
.content-html h3,
.content-html div,
.content-html span,
.content-html ul,
.content-html ol,
.content-html li {
  max-width: 100%;
  box-sizing: border-box;
}

.content-html img {
  max-width: 100%;
  height: auto;
  margin: 20rpx 0;
}

/* 视频样式 */
.content-video {
  width: 100%;
  margin: 20rpx 0;
  border-radius: 8rpx;
}

.content-html p {
  margin: 15rpx 0;
}

.content-html h1,
.content-html h2,
.content-html h3 {
  font-weight: bold;
  margin: 25rpx 0 15rpx 0;
  color: #333;
}

.content-html h1 {
  font-size: 32rpx;
}

.content-html h2 {
  font-size: 30rpx;
}

.content-html h3 {
  font-size: 28rpx;
}

.no-content {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  padding: 40rpx 0;
}

/* 评论区域 */
.review-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  cursor: pointer;
}

.review-section:active {
  background: #f8f8f8;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.title-with-icon {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.title-with-icon .icon {
  font-size: 32rpx;
}

.more-link {
  font-size: 24rpx;
  color: #ff6b6b;
}

.review-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.rating-info {
  display: flex;
  align-items: baseline;
}

.rating-score {
  font-size: 48rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.rating-desc {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.rating-stats {
  display: flex;
  gap: 20rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #666;
}

.no-reviews {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15rpx;
}

.empty-icon {
  font-size: 60rpx;
}

.quantity-section {
  background: #fff;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.quantity-control {
  display: flex;
  align-items: center;
}

.quantity-btn {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  background: #f8f8f8;
  font-size: 32rpx;
  color: #333;
}

.quantity-input {
  width: 80rpx;
  height: 60rpx;
  text-align: center;
  background: #f8f8f8;
  margin: 0 4rpx;
  font-size: 28rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.action-btn {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 30rpx;
  color: #fff;
}

.cart-btn {
  background: #ffa500;
}

.buy-btn {
  background: #ff6b6b;
}
