<view class="container" wx:if="{{product}}">
  <swiper class="product-swiper" indicator-dots autoplay>
    <swiper-item wx:for="{{product.images}}" wx:key="index">
      <image class="product-image" src="{{item}}" mode="aspectFill" />
    </swiper-item>
  </swiper>

  <view class="product-info">
    <view class="price-row">
      <text class="price">¥{{product.price}}</text>
      <text class="original-price">¥{{product.original_price}}</text>
    </view>
    <text class="product-name">{{product.name}}</text>
    <view class="product-desc">
      <text>{{product.description || '暂无描述'}}</text>
    </view>
    <!-- 点赞和收藏按钮 -->
    <view class="interaction-bar">
      <view class="interaction-item" bindtap="onLikeTap">
        <text class="icon {{isLiked ? 'active' : ''}}">{{isLiked ? '❤️' : '🤍'}}</text>
        <text class="count">{{product.like_count || 0}}</text>
      </view>
      <view class="interaction-item" bindtap="onFavoriteTap">
        <text class="icon {{isFavorited ? 'active' : ''}}">{{isFavorited ? '⭐' : '☆'}}</text>
        <text class="count">{{isFavorited ? '已收藏' : '收藏'}}</text>
      </view>
    </view>
  </view>

  <view class="product-content">
    <view class="section-title">商品详情</view>
    <view wx:if="{{contentSegments.length > 0}}">
      <!-- 遍历内容片段 -->
      <block wx:for="{{contentSegments}}" wx:key="index">
        <!-- 视频片段 -->
        <video 
          wx:if="{{item.type === 'video'}}"
          class="content-video"
          src="{{item.src}}"
          poster="{{item.poster || ''}}"
          controls
          show-center-play-btn
          enable-progress-gesture
          object-fit="contain"
        ></video>
        <!-- HTML片段 -->
        <rich-text 
          wx:if="{{item.type === 'html'}}"
          class="content-html" 
          nodes="{{item.content}}"
        ></rich-text>
      </block>
    </view>
    <view class="no-content" wx:else>暂无详情</view>
  </view>

  <!-- 评论区域 -->
  <view class="review-section" bindtap="onViewReviews">
    <view class="section-header">
      <view class="title-with-icon">
        <text class="section-title">商品评价</text>
      </view>
      <text class="more-link">查看全部 ›</text>
    </view>
    <view class="review-summary" wx:if="{{reviewStats}}">
      <view class="rating-info">
        <text class="rating-score">{{reviewStats.average_rating || 0}}</text>
        <text class="rating-desc">分</text>
      </view>
      <view class="rating-stats">
        <text class="stat-item">共 {{reviewStats.total_count || 0}} 条评价</text>
      </view>
    </view>
    <view class="no-reviews" wx:else>
      <text class="empty-icon">📝</text>
      <text>暂无评价，快来抢沙发吧~</text>
    </view>
  </view>

  <view class="address-section" bindtap="onAddressTap">
      <view class="section-title">收货地址</view>
      <view class="address-content" wx:if="{{selectedAddress}}">
        <view class="address-info">
          <text class="consignee">{{selectedAddress.consignee}} {{selectedAddress.phone}}</text>
          <text class="address-detail">{{selectedAddress.province}}{{selectedAddress.city}}{{selectedAddress.district}}{{selectedAddress.address}}</text>
        </view>
        <text class="arrow">></text>
      </view>
      <view class="address-content" wx:else>
        <text class="no-address">请选择收货地址</text>
        <text class="arrow">></text>
      </view>
    </view>

  <view class="quantity-section">
    <text class="section-title">购买数量</text>
    <view class="quantity-control">
      <text class="quantity-btn" bindtap="onQuantityChange" data-type="minus">-</text>
      <input class="quantity-input" type="number" value="{{quantity}}" bindchange="onQuantityChange" />
      <text class="quantity-btn" bindtap="onQuantityChange" data-type="plus">+</text>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="action-btn cart-btn" bindtap="onAddCart">加入购物车</view>
    <view class="action-btn buy-btn" bindtap="onBuyNow">立即购买</view>
  </view>
</view>
