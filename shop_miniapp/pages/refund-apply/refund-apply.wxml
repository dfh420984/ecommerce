<!--pages/refund-apply/refund-apply.wxml-->
<view class="container">
  <!-- 订单信息 -->
  <view class="section">
    <view class="section-title">订单信息</view>
    <view class="order-info">
      <view class="info-item">
        <text class="label">订单号：</text>
        <text class="value">{{orderNo}}</text>
      </view>
      <view class="info-item">
        <text class="label">实付金额：</text>
        <text class="value price">¥{{payAmount}}</text>
      </view>
    </view>
  </view>

  <!-- 退款类型 -->
  <view class="section">
    <view class="section-title">退款类型</view>
    <radio-group bindchange="onRefundTypeChange">
      <label class="radio-item">
        <radio value="refund_only" checked="{{refundType === 'refund_only'}}" />
        <text>仅退款</text>
      </label>
      <label class="radio-item">
        <radio value="exchange" checked="{{refundType === 'exchange'}}" />
        <text>换货</text>
      </label>
    </radio-group>
  </view>

  <!-- 退款金额 -->
  <view class="section">
    <view class="section-title">退款金额</view>
    <view class="amount-input">
      <text class="symbol">¥</text>
      <input 
        type="digit" 
        value="{{refundAmount}}" 
        bindinput="onRefundAmountInput"
        placeholder="请输入退款金额"
        maxlength="10"
      />
    </view>
    <view class="tip">最多可退 ¥{{payAmount}}</view>
  </view>

  <!-- 退款原因 -->
  <view class="section">
    <view class="section-title">退款原因</view>
    <textarea 
      class="reason-textarea"
      value="{{reason}}"
      bindinput="onReasonInput"
      placeholder="请详细描述退款原因"
      maxlength="500"
      show-confirm-bar="{{false}}"
    />
    <view class="char-count">{{reason.length}}/500</view>
  </view>

  <!-- 凭证图片 -->
  <view class="section">
    <view class="section-title">凭证图片（选填）</view>
    <view class="image-list">
      <view 
        class="image-item" 
        wx:for="{{images}}" 
        wx:key="index"
      >
        <image src="{{item}}" mode="aspectFill" />
        <view class="delete-btn" data-index="{{index}}" bindtap="deleteImage">×</view>
      </view>
      <view class="upload-btn" bindtap="chooseImage" wx:if="{{images.length < 3}}">
        <text class="icon">+</text>
        <text class="text">上传图片</text>
      </view>
    </view>
    <view class="tip">最多上传3张图片</view>
  </view>

  <!-- 提交按钮 -->
  <view class="footer">
    <button 
      class="submit-btn" 
      bindtap="submitRefund"
      disabled="{{submitting}}"
    >
      {{submitting ? '提交中...' : '提交申请'}}
    </button>
  </view>
</view>
