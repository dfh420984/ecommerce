.container {
  min-height: 100vh;
  background: #f8f8f8;
  padding-bottom: 120rpx;
}

.cart-list {
  padding: 20rpx 30rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.item-select {
  margin-right: 20rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
}

.checkbox.checked {
  background: #ff6b6b;
  border-color: #ff6b6b;
  position: relative;
}

.checkbox.checked::after {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 6rpx;
  width: 12rpx;
  height: 20rpx;
  border: 4rpx solid #fff;
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.item-name {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.item-price {
  font-size: 32rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.quantity-control {
  display: flex;
  align-items: center;
}

.quantity-btn {
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  background: #f8f8f8;
  font-size: 28rpx;
  color: #333;
}

.quantity-input {
  width: 60rpx;
  height: 50rpx;
  text-align: center;
  background: #f8f8f8;
  margin: 0 4rpx;
  font-size: 28rpx;
}

.item-delete {
  margin-left: 20rpx;
  color: #999;
  font-size: 24rpx;
}

.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

.empty-btn {
  width: 240rpx;
  height: 70rpx;
  line-height: 70rpx;
  background: #ff6b6b;
  color: #fff;
  font-size: 28rpx;
  border-radius: 35rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.select-all {
  display: flex;
  align-items: center;
}

.select-all text {
  margin-left: 10rpx;
  font-size: 28rpx;
  color: #666;
}

.total-info {
  flex: 1;
  text-align: right;
  margin-right: 20rpx;
}

.total-label {
  font-size: 28rpx;
  color: #666;
}

.total-price {
  font-size: 36rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.checkout-btn {
  width: 180rpx;
  height: 70rpx;
  line-height: 70rpx;
  background: #ff6b6b;
  color: #fff;
  font-size: 28rpx;
  text-align: center;
  border-radius: 35rpx;
}
