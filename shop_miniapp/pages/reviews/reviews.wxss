.container {
  min-height: 100vh;
  background: #f8f8f8;
  padding: 20rpx;
}

.review-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.review-item {
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.review-item:last-child {
  border-bottom: none;
}

.review-header {
  display: flex;
  margin-bottom: 20rpx;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.review-time {
  font-size: 24rpx;
  color: #999;
}

.review-content {
  margin-bottom: 20rpx;
}

.review-rating {
  margin-bottom: 10rpx;
}

.stars {
  color: #ffaa00;
  font-size: 32rpx;
}

.review-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 15rpx;
}

.review-images {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.review-image {
  width: 160rpx;
  height: 160rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
}

.review-reply {
  background: #f8f8f8;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-top: 15rpx;
}

.reply-label {
  font-size: 24rpx;
  color: #666;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.reply-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.loading-tip, .empty-tip {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 24rpx;
}
