.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 搜索框 */
.search-box {
  position: relative;
  padding: 20rpx 30rpx;
  background: #fff;
}

.search-input {
  width: 100%;
  height: 70rpx;
  background: #f5f5f5;
  border-radius: 35rpx;
  padding: 0 80rpx 0 30rpx;
  font-size: 28rpx;
}

.search-icon {
  position: absolute;
  right: 50rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 36rpx;
  height: 36rpx;
}

/* 分类列表 */
.category-list {
  display: flex;
  background: #fff;
  margin-top: 20rpx;
  padding: 20rpx 0;
  overflow-x: auto;
  white-space: nowrap;
}

.category-item {
  flex-shrink: 0;
  padding: 12rpx 30rpx;
  margin: 0 10rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 30rpx;
  transition: all 0.3s;
}

.category-item:first-child {
  margin-left: 30rpx;
}

.category-item:last-child {
  margin-right: 30rpx;
}

.category-item.active {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e8e 100%);
  color: #fff;
}

.category-name {
  display: inline-block;
}

/* 问题列表 */
.question-list {
  margin-top: 20rpx;
  padding: 0 30rpx;
}

.question-item {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.question-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
}

.question-title {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  padding-right: 20rpx;
}

.arrow {
  font-size: 24rpx;
  color: #999;
  transition: transform 0.3s;
}

.question-answer {
  padding: 0 30rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.answer-text {
  display: block;
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  white-space: pre-line;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 联系客服 */
.contact-section {
  margin: 40rpx 30rpx;
  padding: 40rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
}

.contact-title {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}

.contact-buttons {
  display: flex;
  gap: 20rpx;
}

.contact-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.contact-btn::after {
  border: none;
}

.contact-btn.online {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.contact-btn.phone {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
}

.btn-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.service-time {
  text-align: center;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999;
}
