<view class="container">
  <view class="address-section" bindtap="onAddressTap">
    <view class="address-content" wx:if="{{selectedAddress}}">
      <view class="address-info">
        <text class="consignee">{{selectedAddress.consignee}} {{selectedAddress.phone}}</text>
        <text class="address-detail">{{selectedAddress.province}}{{selectedAddress.city}}{{selectedAddress.district}}{{selectedAddress.address}}</text>
      </view>
      <text class="arrow">></text>
    </view>
    <view class="address-content" wx:else>
      <text class="no-address">请选择收货地址</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="remark-section">
    <input class="remark-input" placeholder="备注信息(选填)" value="{{remark}}" bindinput="onRemarkInput" />
  </view>

  <!-- 优惠券选择区域 -->
  <view class="coupon-section" wx:if="{{usableCoupons.length > 0}}">
    <view class="coupon-content" bindtap="onShowCouponSelector">
      <view class="coupon-info">
        <text class="coupon-label">优惠券</text>
        <view class="coupon-detail" wx:if="{{selectedCoupon}}">
          <text class="coupon-name">{{selectedCoupon.coupon.name}}</text>
          <text class="coupon-discount">-¥{{couponDiscount}}</text>
        </view>
        <view class="coupon-detail" wx:else>
          <text class="coupon-tip">有{{usableCoupons.length}}张可用</text>
        </view>
      </view>
      <view class="coupon-actions">
        <text class="arrow">></text>
        <text class="cancel-btn" wx:if="{{selectedCoupon}}" catchtap="onCancelCoupon">不使用</text>
      </view>
    </view>
  </view>
  <view class="coupon-section" wx:else>
    <view class="coupon-content">
      <view class="coupon-info">
        <text class="coupon-label">优惠券</text>
        <text class="coupon-tip">暂无可用优惠券</text>
      </view>
    </view>
  </view>

  <view class="order-section" wx:if="{{orderItems.length}}">
    <view class="order-item" wx:for="{{orderItems}}" wx:key="id">
      <image class="item-image" src="{{item.product_image || '/static/product.png'}}" mode="aspectFill" />
      <view class="item-info">
        <text class="item-name">{{item.product_name}}</text>
        <view class="item-bottom">
          <text class="item-price">¥{{item.price}}</text>
          <text class="item-quantity">x{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="total-info">
      <view class="amount-row">
        <text class="total-label">合计:</text>
        <text class="total-price">¥{{finalAmount}}</text>
      </view>
      <view class="discount-row" wx:if="{{couponDiscount > 0}}">
        <text class="discount-text">已优惠¥{{couponDiscount}}</text>
      </view>
    </view>
    <view class="submit-btn" bindtap="onSubmit">提交订单</view>
  </view>
</view>
