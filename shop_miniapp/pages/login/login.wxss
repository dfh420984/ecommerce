.container {
  min-height: 100vh;
  background: #fff;
  padding: 100rpx 60rpx;
}

.login-header {
  margin-bottom: 80rpx;
}

.login-title {
  font-size: 48rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: #999;
  display: block;
}

.login-form {
  margin-bottom: 60rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-input {
  height: 88rpx;
  background: #f8f8f8;
  border-radius: 44rpx;
  padding: 0 40rpx;
  font-size: 28rpx;
}

.form-btn {
  height: 88rpx;
  line-height: 88rpx;
  background: #ff6b6b;
  color: #fff;
  font-size: 30rpx;
  text-align: center;
  border-radius: 44rpx;
  margin-bottom: 30rpx;
}

.wechat-btn {
  background: #07c160;
}

.register-tip {
  text-align: center;
  font-size: 26rpx;
  color: #999;
}

.register-link {
  color: #ff6b6b;
  margin-left: 10rpx;
}
