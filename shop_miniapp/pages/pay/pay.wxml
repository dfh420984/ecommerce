<view class="container" wx:if="{{order}}">
  <view class="order-info">
    <view class="order-amount">
      <text class="amount-label">订单金额</text>
      <text class="amount-value">¥{{order.pay_amount}}</text>
    </view>
    <view class="order-no">订单号: {{order.order_no}}</view>
    <!-- 已支付标识 -->
    <view class="paid-badge" wx:if="{{paid}}">
      <text class="badge-icon">✓</text>
      <text class="badge-text">已支付</text>
    </view>
  </view>

  <view class="pay-section" wx:if="{{!paid}}">
    <view class="section-title">选择支付方式</view>
    <view class="pay-types">
      <view class="pay-type-item {{selectedPayType === 1 ? 'selected' : ''}}" bindtap="onPayTypeChange" data-id="1">
        <view class="pay-info">
          <image class="pay-icon" src="/static/pay/wechat.png" mode="aspectFit" />
          <text class="pay-name">微信支付</text>
        </view>
        <view class="pay-check"></view>
      </view>
      <view class="pay-type-item {{selectedPayType === 2 ? 'selected' : ''}}" bindtap="onPayTypeChange" data-id="2">
        <view class="pay-info">
          <image class="pay-icon" src="/static/pay/alipay.png" mode="aspectFit" />
          <text class="pay-name">支付宝</text>
        </view>
        <view class="pay-check"></view>
      </view>
    </view>
  </view>

  <view class="action-section">
    <view class="ghost-btn" bindtap="goOrderList">查看订单</view>
    <view class="ghost-btn" bindtap="goHome">返回首页</view>
  </view>

  <view class="pay-bar" wx:if="{{!paid}}">
    <view class="pay-info">
      <text class="pay-label">实付:</text>
      <text class="pay-amount">¥{{order.pay_amount}}</text>
    </view>
    <view class="pay-btn {{paying ? 'disabled' : ''}}" bindtap="onPay">
      {{paying ? '支付中...' : '立即支付'}}
    </view>
  </view>
  
  <!-- 已支付状态下的按钮 -->
  <view class="pay-bar paid-bar" wx:if="{{paid}}">
    <view class="view-order-btn" bindtap="goOrderDetail">查看订单详情</view>
  </view>
</view>
