.container {
  min-height: 100vh;
  background: #f8f8f8;
  padding-bottom: 120rpx;
}

.order-info {
  background: #fff;
  padding: 40rpx 30rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.order-amount {
  margin-bottom: 20rpx;
}

.amount-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}

.amount-value {
  font-size: 56rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

/* 优惠券信息 */
.coupon-info {
  margin-top: 15rpx;
}

.coupon-text {
  font-size: 24rpx;
  color: #ff6b6b;
}

/* 已支付标识 */
.paid-badge {
  margin-top: 20rpx;
  display: inline-flex;
  align-items: center;
  background: #52c41a;
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.badge-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
  font-weight: bold;
}

.badge-text {
  font-size: 26rpx;
}

.pay-section {
  background: #fff;
  padding: 30rpx;
}

.action-section {
  margin-top: 20rpx;
  background: #fff;
  padding: 0 30rpx;
}

.ghost-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  border-bottom: 1rpx solid #f5f5f5;
}

.ghost-btn:last-child {
  border-bottom: none;
}

.section-title {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.pay-types {
  display: flex;
  flex-direction: column;
}

.pay-type-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s;
}

.pay-type-item:active {
  opacity: 0.7;
}

.pay-type-item:last-child {
  border-bottom: none;
}

.pay-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.pay-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.pay-name {
  font-size: 28rpx;
  color: #333;
}

.pay-type-item.selected .pay-name {
  color: #ff6b6b;
  font-weight: bold;
}

.pay-check {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.pay-type-item.selected .pay-check {
  background: #ff6b6b;
  border-color: #ff6b6b;
  position: relative;
}

.pay-type-item.selected .pay-check::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) rotate(45deg);
  width: 8rpx;
  height: 16rpx;
  border-right: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  margin-top: -2rpx;
}

.pay-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.pay-info {
  display: flex;
  align-items: center;
}

.pay-label {
  font-size: 28rpx;
  color: #666;
}

.pay-amount {
  font-size: 40rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.pay-btn {
  width: 200rpx;
  height: 70rpx;
  line-height: 70rpx;
  background: #ff6b6b;
  color: #fff;
  font-size: 30rpx;
  text-align: center;
  border-radius: 35rpx;
}

.pay-btn.disabled {
  background: #ccc;
  opacity: 0.6;
}

/* 已支付状态下的按钮 */
.paid-bar {
  justify-content: center;
}

.view-order-btn {
  width: 400rpx;
  height: 70rpx;
  line-height: 70rpx;
  background: #52c41a;
  color: #fff;
  font-size: 30rpx;
  text-align: center;
  border-radius: 35rpx;
}
