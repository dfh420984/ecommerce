<view class="container">
  <view class="about-header">
    <image class="logo" src="{{logo}}" mode="aspectFit" />
    <text class="app-name">{{shopName}}</text>
    <text class="version">版本 {{version}}</text>
  </view>

  <view class="about-content">
    <view class="info-item" wx:if="{{intro}}">
      <text class="label">关于我们</text>
      <text class="value">{{intro}}</text>
    </view>
    
    <view class="info-item" wx:if="{{techStack}}">
      <text class="label">技术栈</text>
      <text class="value">{{techStack}}</text>
    </view>
    
    <view class="info-item" wx:if="{{contact}}">
      <text class="label">联系方式</text>
      <text class="value">{{contact}}</text>
    </view>
    
    <view class="info-item">
      <text class="label">营业时间</text>
      <text class="value">{{businessHours || '09:00-21:00'}}</text>
    </view>
    
    <view class="info-item">
      <text class="label">退换货政策</text>
      <text class="value">{{returnPolicy || '7天无理由退换货'}}</text>
    </view>
  </view>
</view>
