<view class="container">
  <view class="register-header">
    <text class="register-title">创建账号</text>
    <text class="register-subtitle">注册后享受更多服务</text>
  </view>

  <view class="register-form">
    <view class="form-item">
      <text class="form-label">用户名</text>
      <input class="form-input" placeholder="请输入用户名（3-50个字符）" value="{{username}}" bindinput="onUsernameInput" maxlength="50" />
    </view>
    <view class="form-item">
      <text class="form-label">密码</text>
      <input class="form-input" type="password" placeholder="请输入密码（6-50个字符）" value="{{password}}" bindinput="onPasswordInput" maxlength="50" />
    </view>
    <view class="form-item">
      <text class="form-label">确认密码</text>
      <input class="form-input" type="password" placeholder="请再次输入密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" maxlength="50" />
    </view>
    <view class="form-item">
      <text class="form-label">手机号（选填）</text>
      <input class="form-input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" maxlength="11" />
    </view>
    <view class="form-btn" bindtap="onRegister">注册</view>
  </view>

  <view class="login-tip">
    <text>已有账号?</text>
    <text class="login-link" bindtap="onGoLogin">立即登录</text>
  </view>
</view>
