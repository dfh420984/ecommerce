.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #ff6b6b 0%, #f8f8f8 40%);
  padding: 0 30rpx;
}

.register-header {
  padding: 80rpx 0 60rpx;
  text-align: center;
}

.register-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.register-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.register-form {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 15rpx;
}

.form-input {
  width: 100%;
  height: 90rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 25rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-btn {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e8e 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 50rpx;
}

.login-tip {
  text-align: center;
  margin-top: 40rpx;
  font-size: 26rpx;
  color: #666;
}

.login-link {
  color: #ff6b6b;
  font-weight: bold;
  margin-left: 10rpx;
}
