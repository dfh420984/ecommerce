<view class="container">
  <view class="address-list">
    <view class="address-item {{mode === 'select' && selectedId === item.id ? 'address-item-selected' : ''}}" wx:for="{{addresses}}" wx:key="id" bindtap="onAddressTap" data-id="{{item.id}}">
      <view class="address-content">
        <view class="address-main">
          <text class="consignee">{{item.consignee}}</text>
          <text class="phone">{{item.phone}}</text>
          <view class="default-tag" wx:if="{{item.is_default === 1}}">默认</view>
        </view>
        <text class="address-detail">{{item.province}}{{item.city}}{{item.district}}{{item.address}}</text>
      </view>
      <view class="address-actions" catchtap="onAddressTap" data-id="{{item.id}}">
        <view class="action-btn" bindtap="onSetDefault" data-id="{{item.id}}">
          <text>{{item.is_default === 1 ? '默认地址' : '设为默认'}}</text>
        </view>
        <view class="action-btn delete-btn" bindtap="onDeleteAddress" data-id="{{item.id}}">删除</view>
      </view>
    </view>
  </view>

  <view class="empty-tip" wx:if="{{addresses.length === 0}}">
    <text>暂无收货地址</text>
  </view>

  <view class="bottom-bar">
    <view class="add-btn" bindtap="onAddAddress">添加收货地址</view>
  </view>
</view>
