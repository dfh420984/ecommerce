.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-title {
  padding: 30rpx;
  background: #fff;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
  text-align: center;
}

.product-scroll {
  flex: 1;
  padding: 20rpx;
  background: #fff;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx;
}

.product-item {
  width: calc(50% - 20rpx);
  padding: 0 10rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.product-image {
  width: 100%;
  height: 300rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.product-info {
  padding: 16rpx 10rpx;
}

.product-name {
  font-size: 26rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-bottom {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.product-price {
  font-size: 30rpx;
  color: #ff6b6b;
  font-weight: bold;
}

.product-original {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
}

.loading-tip, .empty-tip {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 24rpx;
}
