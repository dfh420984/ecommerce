<view class="container">
  <!-- 搜索框 -->
  <view class="search-bar" wx:if="{{type === 'search'}}">
    <view class="search-input-wrapper">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索商品" value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearchConfirm" />
      <text class="search-clear" wx:if="{{keyword}}" bindtap="onClearSearch">✕</text>
    </view>
  </view>

  <!-- 页面标题 -->
  <view class="page-title" wx:if="{{type !== 'search'}}">
    <text>{{title}}</text>
  </view>
  
  <!-- 商品列表 -->
  <scroll-view class="product-scroll" scroll-y bindscrolltolower="onReachBottom">
    <view class="product-grid">
      <view class="product-item" wx:for="{{products}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}">
        <image class="product-image" src="{{item.images[0] || '/static/product.png'}}" mode="aspectFill" />
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <view class="product-bottom">
            <text class="product-price">¥{{item.price}}</text>
            <text class="product-original" wx:if="{{item.original_price}}">¥{{item.original_price}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="loading-tip" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    <view class="loading-tip" wx:elif="{{!hasMore && products.length > 0}}">
      <text>没有更多了</text>
    </view>
    <view class="empty-tip" wx:if="{{products.length === 0 && !loading}}">
      <text>暂无商品</text>
    </view>
  </scroll-view>
</view>
