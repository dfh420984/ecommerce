/* pages/logistics/logistics.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 快递信息卡片 */
.express-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  color: #fff;
}

.express-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.company-info {
  flex: 1;
}

.company-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.express-no {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
}

.copy-btn {
  padding: 10rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  font-size: 26rpx;
}

/* 物流轨迹 */
.tracks-container {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}

.track-item {
  display: flex;
  position: relative;
  padding-bottom: 40rpx;
}

.track-item:last-child {
  padding-bottom: 0;
}

/* 时间线 */
.timeline {
  position: relative;
  width: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #ddd;
  z-index: 1;
  flex-shrink: 0;
}

.dot.active {
  background: #667eea;
  box-shadow: 0 0 0 8rpx rgba(102, 126, 234, 0.2);
}

.line {
  width: 2rpx;
  flex: 1;
  background: #eee;
  margin-top: 10rpx;
}

/* 内容 */
.track-content {
  flex: 1;
  padding-left: 20rpx;
}

.track-content.latest {
  color: #667eea;
}

.track-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.track-content.latest .track-time {
  color: #667eea;
}

.track-status {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

.track-content.latest .track-status {
  color: #333;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #ccc;
}

/* 加载中 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  font-size: 28rpx;
  color: #999;
}
